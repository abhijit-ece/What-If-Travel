# =========================================================================
# AI WHAT-IF TRAVEL SIMULATOR - ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to '.env' and populate the actual values.
# NEVER commit the '.env' file with real credentials to source control.

# --- Backend Configuration ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# MySQL Database Configuration (for Prod/Local MySQL profile)
DB_URL=jdbc:mysql://localhost:3306/travel_simulator?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# JWT Authentication Configuration
# Must be a secure base64-encoded or plain string, at least 256 bits (32 bytes) long
JWT_SECRET=super_secret_jwt_key_at_least_256_bits_long_for_security_reasons_12345
JWT_EXPIRATION_MS=86400000

# --- External API Keys ---
# Weather API - OpenWeatherMap (free tier key)
WEATHER_API_KEY=your_openweathermap_api_key_here

# LLM API Provider (gemini or openai)
LLM_PROVIDER=gemini
# LLM API Secret Key (e.g. Gemini key or OpenAI API key)
LLM_API_KEY=your_gemini_api_key_here
